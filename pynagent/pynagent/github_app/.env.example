# =============================================================================
# PyNEAT GitHub App — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# GitHub App Settings (from GitHub App settings page)
# ---------------------------------------------------------------------------
APP_ID=123456
WEBHOOK_SECRET=replace_with_a_random_secret_at_least_20_chars

# Path to the private key PEM file (generate at GitHub App settings page)
PRIVATE_KEY_PATH=./private-key.pem

# ---------------------------------------------------------------------------
# PyNEAT Configuration
# ---------------------------------------------------------------------------
PYNEAT_CLI_PATH=pyneat
PYNEAT_FORMAT=sarif
PYNEAT_MIN_SEVERITY=low
PYNEAT_FAIL_ON=critical
PYNEAT_AUTO_FIX=false
PYNEAT_LANGUAGES=python,javascript,typescript,go,java,rust,ruby,php

# ---------------------------------------------------------------------------
# LLM Provider for AI Analysis
# ---------------------------------------------------------------------------
# Auto-detected in priority order. Set at least ONE of these:

# --- OPTION 1: DeepSeek on Ollama Cloud (RECOMMENDED for hackathon) ---
# Get API key from your Ollama Cloud account
# DEEPSEEK_API_KEY=ollama-cloud-api-key-here
# DeepSeek endpoint (Ollama Cloud provides this)
# DEEPSEEK_BASE_URL=https://api.ollama.cloud/v1
# Model name (e.g., deepseek-671b, qwen2.5-72b-instruct)
# DEEPSEEK_MODEL=deepseek-671b

# --- OPTION 2: Ollama (local or custom cloud) ---
# Local: http://localhost:11434/v1
# Cloud: your Ollama Pro/cloud endpoint
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-72b-instruct
# OLLAMA_API_KEY=  (if using Ollama Cloud)

# --- OPTION 3: AMD Developer Cloud ---
# Get your AMD Developer Cloud API key at: https://developer.amd.com/
# AMD_API_KEY=your_amd_api_key_here
# AMD_API_URL=https://api.amd.com/v1
# AMD_MODEL=qwen-2.5-72b-instruct

# --- OPTION 4: OpenAI ---
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- OPTION 5: Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ---------------------------------------------------------------------------
# Shared LLM Settings (applied to all providers)
# ---------------------------------------------------------------------------
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_CACHE_TTL=24

# ---------------------------------------------------------------------------
# AI Analysis Settings
# ---------------------------------------------------------------------------
ENABLE_AI_ANALYSIS=true
AI_ANALYSIS_MIN_SEVERITY=high
AI_ANALYSIS_CACHE_TTL_HOURS=24

# ---------------------------------------------------------------------------
# Job Queue (BullMQ + Redis)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
QUEUE_SCAN_NAME=pyneat-scan
QUEUE_NOTIFY_NAME=pyneat-notify
QUEUE_CONCURRENCY=3
QUEUE_MAX_RETRIES=2

# ---------------------------------------------------------------------------
# Notification Channels
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=pyneat-bot@example.com
SMTP_TO=

# ---------------------------------------------------------------------------
# Server Settings
# ---------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
APP_URL=https://your-server.example.com

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
FEATURE_DRY_RUN=false
FEATURE_CHECKS_API=true
FEATURE_PR_COMMENTS=true
FEATURE_SARIF_UPLOAD=true
FEATURE_INLINE_COMMENTS=true
FEATURE_SLACK_NOTIFY=false
FEATURE_EMAIL_NOTIFY=false
FEATURE_DISCORD_NOTIFY=false

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------
NODE_ENV=production
